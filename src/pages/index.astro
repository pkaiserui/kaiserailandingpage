---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

// Simple feature flags so you can toggle sections on/off
const SHOW_PORTFOLIO = false;
const SHOW_TESTIMONIALS = false;
---

<Layout>
  <!-- ===== NAVBAR ===== -->
  <nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-[background-color,box-shadow,border-color] duration-300 bg-surface/0" aria-label="Main navigation">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="#" class="flex items-center gap-2.5 group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pop focus-visible:ring-offset-2 rounded-lg">
        <span class="text-xl font-bold text-ink">Kaiser <span class="text-gradient">AI</span></span>
      </a>
      <div class="hidden md:flex items-center gap-8">
        <a href="#about" class="text-sm font-medium text-mid hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pop focus-visible:ring-offset-2 rounded">About</a>
        {SHOW_PORTFOLIO && (
          <a href="#portfolio" class="text-sm font-medium text-mid hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pop focus-visible:ring-offset-2 rounded">Work</a>
        )}
        {SHOW_TESTIMONIALS && (
          <a href="#testimonials" class="text-sm font-medium text-mid hover:text-ink transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pop focus-visible:ring-offset-2 rounded">Testimonials</a>
        )}
        <a href="#contact" class="inline-flex items-center gap-2 px-5 py-2.5 bg-pop text-surface text-sm font-semibold rounded-full hover:bg-pop/90 transition-colors shadow-lg shadow-pop/25 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pop focus-visible:ring-offset-2">
          Contact Us
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
      <button id="mobile-toggle" class="md:hidden p-2 text-mid rounded focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pop focus-visible:ring-offset-2" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
    <!-- Mobile Menu -->
    <div id="mobile-menu" class="md:hidden hidden bg-surface/98 backdrop-blur-lg border-t border-surface-alt">
      <div class="px-6 py-4 space-y-3">
        <a href="#about" class="block text-sm font-medium text-mid hover:text-ink py-2">About</a>
        {SHOW_PORTFOLIO && (
          <a href="#portfolio" class="block text-sm font-medium text-mid hover:text-ink py-2">Work</a>
        )}
        {SHOW_TESTIMONIALS && (
          <a href="#testimonials" class="block text-sm font-medium text-mid hover:text-ink py-2">Testimonials</a>
        )}
        <a href="#contact" class="block text-center px-5 py-2.5 bg-pop text-surface text-sm font-semibold rounded-full">Contact Us</a>
      </div>
    </div>
  </nav>

  <!-- ===== HERO ===== -->
  <section class="relative min-h-screen flex items-center hero-mesh grid-pattern overflow-hidden bg-surface">
    <!-- Decorative shapes — soft watercolor diffusion -->
    <div class="absolute top-24 right-12 w-72 h-72 bg-pop/20 rounded-full blur-3xl animate-float pointer-events-none"></div>
    <div class="absolute bottom-32 left-8 w-56 h-56 bg-pop/15 rounded-full blur-3xl animate-float-delayed pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-pop/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative max-w-7xl mx-auto px-6 pt-32 pb-20 grid lg:grid-cols-2 gap-16 items-center">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-surface-alt border border-pop/40 mb-8">
          <span class="w-2 h-2 rounded-full bg-pop animate-pulse"></span>
          <span class="text-sm font-semibold text-pop">AI-Powered Digital Solutions</span>
        </div>
        <h1 id="hero-heading" class="text-5xl sm:text-6xl lg:text-7xl font-extrabold leading-[1.08] tracking-tight text-ink mb-6 font-[family-name:var(--font-display)]">
          Build Digital Products That
          <span class="text-gradient"> Scale</span>
        </h1>
        <p class="text-lg sm:text-xl text-mid leading-relaxed mb-10 max-w-xl">
          From custom mobile apps to AI-driven platforms, Kaiser AI transforms your ideas into high-performance digital products built for long-term growth.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#contact" class="inline-flex items-center gap-2 px-8 py-4 bg-pop text-surface font-semibold rounded-full hover:bg-pop/90 transition-colors shadow-xl shadow-pop/30 pulse-cta focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-pop focus-visible:ring-offset-2">
            Start Your Project
            <svg class="w-5 h-5" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>

        </div>
        <!-- Trust signals -->
        <div class="mt-14 flex items-center gap-8 text-sm text-mid">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-pop" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>iOS & Android</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-pop" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>Full-Stack Web</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-pop" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
            <span>AI & ML</span>
          </div>
        </div>
      </div>

      <!-- Hero visual: Kaiser AI brand artwork -->
      <div class="hidden lg:flex justify-center items-center relative">
        <img
          src={`${base}kaiser-logo.png`}
          alt="Kaiser AI — abstract fluid design representing innovation and connectivity"
          width="480"
          height="360"
          class="relative max-w-md w-full h-auto object-contain rounded-2xl shadow-xl shadow-ink/10"
          fetchpriority="high"
        />
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-2 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-muted/70">
      <div class="w-5 h-8 rounded-full border-2 border-muted/50 flex justify-center pt-1.5 opacity-60">
          <div class="w-1 h-2 rounded-full bg-pop/80 animate-bounce"></div>
      </div>
      <span class="text-xs font-medium tracking-widest uppercase">Scroll</span>
    </div>
  </section>

  <!-- ===== ABOUT ===== -->
  <section id="about" class="py-24 sm:py-32 bg-surface-alt">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- Left: text -->
        <div class="reveal-left">
          <span class="inline-block text-sm font-semibold text-pop tracking-widest uppercase mb-4">About Us</span>
          <h2 class="text-4xl sm:text-5xl font-extrabold text-ink leading-tight mb-6">
            Engineering the Future,<br/>
            <span class="text-gradient">One Product at a Time</span>
          </h2>
          <p class="text-lg text-mid leading-relaxed mb-6">
            Kaiser AI is a technology company specializing in the design and development of custom mobile applications, web platforms, and AI-powered digital solutions. We help startups, small businesses, and growing enterprises transform ideas into scalable, high-performance digital products.
          </p>
          <p class="text-lg text-mid leading-relaxed">
            We combine modern software engineering with artificial intelligence to build intuitive user experiences, automation systems, and data-driven applications — prioritizing clean architecture, security, scalability, and performance in everything we build.
          </p>
        </div>

        <!-- Right: services grid -->
        <div class="reveal-right">
          <div class="grid grid-cols-2 gap-4 stagger">
            <div class="card-hover p-6 rounded-2xl bg-surface border border-surface-alt shadow-sm" style="--stagger:0">
              <div class="w-12 h-12 rounded-xl bg-surface-alt flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-pop" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-6 18.75h6"/></svg>
              </div>
              <h3 class="font-bold text-ink mb-1">Mobile Apps</h3>
              <p class="text-sm text-muted">Native iOS & Android development with beautiful UIs</p>
            </div>
            <div class="card-hover p-6 rounded-2xl bg-surface border border-surface-alt shadow-sm" style="--stagger:1">
              <div class="w-12 h-12 rounded-xl bg-surface-alt flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-pop" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/></svg>
              </div>
              <h3 class="font-bold text-ink mb-1">Web Platforms</h3>
              <p class="text-sm text-muted">Responsive, full-stack web development</p>
            </div>
            <div class="card-hover p-6 rounded-2xl bg-surface border border-surface-alt shadow-sm" style="--stagger:2">
              <div class="w-12 h-12 rounded-xl bg-surface-alt flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-pop" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>
              </div>
              <h3 class="font-bold text-ink mb-1">AI Solutions</h3>
              <p class="text-sm text-muted">Chatbots, ML models & workflow automation</p>
            </div>
            <div class="card-hover p-6 rounded-2xl bg-surface border border-surface-alt shadow-sm" style="--stagger:3">
              <div class="w-12 h-12 rounded-xl bg-surface-alt flex items-center justify-center mb-4">
                <svg class="w-6 h-6 text-pop" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z"/></svg>
              </div>
              <h3 class="font-bold text-ink mb-1">Cloud & APIs</h3>
              <p class="text-sm text-muted">Scalable cloud integration & API development</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {SHOW_PORTFOLIO && (
    <>
      <!-- ===== PORTFOLIO ===== -->
      <section id="portfolio" class="py-24 sm:py-32 bg-surface">
        <div class="max-w-7xl mx-auto px-6">
          <div class="text-center mb-16 reveal">
            <span class="inline-block text-sm font-semibold text-pop tracking-widest uppercase mb-4">Our Work</span>
            <h2 class="text-4xl sm:text-5xl font-extrabold text-ink leading-tight mb-4">
              Projects That <span class="text-gradient">Deliver Results</span>
            </h2>
            <p class="text-lg text-mid max-w-2xl mx-auto">
              We've partnered with ambitious teams to build products that drive real business impact.
            </p>
          </div>

          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 stagger">
            <!-- Project 1 -->
            <div class="reveal card-hover group rounded-3xl overflow-hidden bg-surface border border-surface-alt shadow-sm" style="--stagger:0">
              <div class="aspect-[4/3] bg-brand-gradient relative overflow-hidden">
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="w-20 h-20 text-white/80" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3"/></svg>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
                <span class="absolute bottom-4 left-4 text-xs font-semibold text-surface/90 bg-ink/20 backdrop-blur-sm px-3 py-1 rounded-full">Mobile App</span>
              </div>
              <div class="p-6">
                <h3 class="text-xl font-bold text-ink mb-2 group-hover:text-pop transition-colors">Health & Wellness Platform</h3>
                <p class="text-sm text-muted mb-4">A comprehensive iOS and Android app featuring AI-driven health tracking, personalized insights, and real-time biometric data visualization.</p>
                <div class="flex flex-wrap gap-2">
                  <span class="px-3 py-1 text-xs font-medium bg-surface-alt text-mid rounded-full">React Native</span>
                  <span class="px-3 py-1 text-xs font-medium bg-surface-alt text-mid rounded-full">ML Models</span>
                  <span class="px-3 py-1 text-xs font-medium bg-surface-alt text-mid rounded-full">HealthKit</span>
                </div>
              </div>
            </div>

            <!-- Project 2 -->
            <div class="reveal card-hover group rounded-3xl overflow-hidden bg-surface border border-surface-alt shadow-sm" style="--stagger:1">
              <div class="aspect-[4/3] bg-brand-gradient relative overflow-hidden">
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="w-20 h-20 text-white/80" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25"/></svg>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
                <span class="absolute bottom-4 left-4 text-xs font-semibold text-surface/90 bg-ink/20 backdrop-blur-sm px-3 py-1 rounded-full">Web Platform</span>
              </div>
              <div class="p-6">
                <h3 class="text-xl font-bold text-ink mb-2 group-hover:text-pop transition-colors">E-Commerce Analytics Dashboard</h3>
                <p class="text-sm text-muted mb-4">A real-time analytics platform helping online retailers track sales, optimize inventory, and predict trends using machine learning algorithms.</p>
                <div class="flex flex-wrap gap-2">
                  <span class="px-3 py-1 text-xs font-medium bg-surface-alt text-mid rounded-full">Next.js</span>
                  <span class="px-3 py-1 text-xs font-medium bg-surface-alt text-mid rounded-full">Python</span>
                  <span class="px-3 py-1 text-xs font-medium bg-surface-alt text-mid rounded-full">AWS</span>
                </div>
              </div>
            </div>

            <!-- Project 3 -->
            <div class="reveal card-hover group rounded-3xl overflow-hidden bg-surface border border-surface-alt shadow-sm" style="--stagger:2">
              <div class="aspect-[4/3] bg-brand-gradient relative overflow-hidden">
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="w-20 h-20 text-white/80" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
                <span class="absolute bottom-4 left-4 text-xs font-semibold text-surface/90 bg-ink/20 backdrop-blur-sm px-3 py-1 rounded-full">AI Automation</span>
              </div>
              <div class="p-6">
                <h3 class="text-xl font-bold text-ink mb-2 group-hover:text-pop transition-colors">AI Customer Service Agent</h3>
                <p class="text-sm text-muted mb-4">An intelligent chatbot system that handles customer inquiries, routes tickets, and resolves common issues autonomously with 94% satisfaction.</p>
                <div class="flex flex-wrap gap-2">
                  <span class="px-3 py-1 text-xs font-medium bg-surface-alt text-mid rounded-full">NLP</span>
                  <span class="px-3 py-1 text-xs font-medium bg-surface-alt text-mid rounded-full">Node.js</span>
                  <span class="px-3 py-1 text-xs font-medium bg-surface-alt text-mid rounded-full">OpenAI</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </>
  )}

  {SHOW_TESTIMONIALS && (
    <>
      <!-- ===== TESTIMONIALS ===== -->
      <section id="testimonials" class="py-24 sm:py-32 bg-surface-alt relative overflow-hidden">
        <div class="absolute top-0 right-0 w-96 h-96 bg-pop/12 rounded-full blur-3xl pointer-events-none"></div>
        <div class="max-w-7xl mx-auto px-6 relative">
          <div class="text-center mb-16 reveal">
              <span class="inline-block text-sm font-semibold text-pop tracking-widest uppercase mb-4">Testimonials</span>
            <h2 class="text-4xl sm:text-5xl font-extrabold text-ink leading-tight mb-4">
              What Our <span class="text-gradient">Clients Say</span>
            </h2>
            <p class="text-lg text-mid max-w-2xl mx-auto">
              Real feedback from teams we've helped bring their visions to life.
            </p>
          </div>

          <div class="grid md:grid-cols-3 gap-8 stagger">
            <!-- Testimonial 1 -->
            <div class="reveal card-hover p-8 rounded-3xl bg-surface border border-surface-alt shadow-sm relative" style="--stagger:0">
              <svg class="absolute top-6 right-6 w-10 h-10 text-muted" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/></svg>
              <div class="flex items-center gap-1 mb-4">
                {[...Array(5)].map(() => (
                  <svg class="w-5 h-5 text-pop" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                ))}
              </div>
              <p class="text-mid leading-relaxed mb-6">
                "Kaiser AI transformed our concept into a polished product in record time. Their team understood our vision immediately and delivered an app that exceeded every expectation."
              </p>
              <div class="flex items-center gap-3">
                <div class="w-11 h-11 rounded-full bg-brand-gradient flex items-center justify-center text-surface font-bold text-sm">JM</div>
                <div>
                  <div class="font-semibold text-ink text-sm">James Mitchell</div>
                  <div class="text-xs text-muted">CEO, HealthTrack</div>
                </div>
              </div>
            </div>

            <!-- Testimonial 2 -->
            <div class="reveal card-hover p-8 rounded-3xl bg-surface border border-surface-alt shadow-sm relative" style="--stagger:1">
              <svg class="absolute top-6 right-6 w-10 h-10 text-muted" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/></svg>
              <div class="flex items-center gap-1 mb-4">
                {[...Array(5)].map(() => (
